# Copy this file to .env and fill in your values.
# .env is gitignored and will not be committed.
#
#   cp .env.example .env

# Force UTF-8 mode (fixes Windows cp1251 issues with redirect to file)
export PYTHONUTF8=1

# ── Bitbucket Server ──────────────────────────────────────────────────────────
export BITBUCKET_URL="https://bitbucket.example.com"
export BITBUCKET_PROJECT="MYPROJ"
export BITBUCKET_REPO="orderflow"
export BITBUCKET_TOKEN="ATBBxxxxxxxx"
export BITBUCKET_AGENT_ACCOUNT="review-bot"

# ── Agent under test ──────────────────────────────────────────────────────────
export AGENT_API_KEY=""

# ── LLM judge ─────────────────────────────────────────────────────────────────
export ANTHROPIC_API_KEY="sk-ant-..."
# If using an OpenAI-compatible endpoint instead of Anthropic:
# export DEEPSEEK_API_KEY="..."

# ── Trace dump (optional) ────────────────────────────────────────────────────
# When set, every benchmark session creates
#   <BENCHMARK_TRACE_DIR>/<timestamp[-label]>/
#     bench.json, summary.json
#     <provider>/<scenario>/attempt-NN/
#       agent/      <- DIFFGRAPH_TRACE_PATH for the diff-graph subprocess
#       judge/      <- judge LLM request.json / response.json
#       result.json
# attempt-NN auto-increments per (provider, scenario) so re-runs of the
# same session measure variance. Different agent versions live under
# separate sessions (timestamp + label) for trend comparison.
# export BENCHMARK_TRACE_DIR=$HOME/bench-traces
# export BENCH_LABEL=v3-prompt-rewrite

# ── Proxy ────────────────────────────────────────────────────────────────────
# If your shell exports SOCKS / HTTP proxies for general use, make sure
# they don't leak into the benchmark. Corporate LLM endpoints on .ru
# domains break with APIConnectionError when traffic gets routed via
# 127.0.0.1:* SOCKS. Either unset before running:
#   unset all_proxy ALL_PROXY http_proxy HTTP_PROXY https_proxy HTTPS_PROXY
# or extend NO_PROXY to cover the LLM host.
