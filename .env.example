# Copy this file to .env and fill in your values.
# .env is gitignored and will not be committed.
#
#   cp .env.example .env

# Force UTF-8 mode (fixes Windows cp1251 issues with redirect to file)
export PYTHONUTF8=1

# ── Bitbucket Server ──────────────────────────────────────────────────────────
export BITBUCKET_URL="https://bitbucket.example.com"
export BITBUCKET_PROJECT="MYPROJ"
export BITBUCKET_REPO="orderflow"
export BITBUCKET_TOKEN="ATBBxxxxxxxx"
export BITBUCKET_AGENT_ACCOUNT="review-bot"

# ── Agent under test ──────────────────────────────────────────────────────────
export AGENT_API_KEY=""

# ── LLM judge ─────────────────────────────────────────────────────────────────
export ANTHROPIC_API_KEY="sk-ant-..."
# If using an OpenAI-compatible endpoint instead of Anthropic:
# export DEEPSEEK_API_KEY="..."
